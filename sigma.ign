class Vector3 {
	constructor(self, x = 0, y = 0, z = 0) {
		self.x = x
		self.y = y
		self.z = z
	}

	fn __tostring__(self) => $"({self.x}, {self.y}, {self.z})"

	fn __mul__(self, other) => new Vector3(
			self.x + other.x,
			self.y + other.y,
			self.z + other.z,
		)
	}
}

println(new Vector3(1, 0, 0) + new Vector3(0, 1, 0))
