import Tetris from "tetris"
using Std::IO::read_key

let game = new Tetris()

game.draw_plr()
game.print_board(true)
println("Score:", game.score)

loop {
	if !game.piece.alive {
		game.clear_lines()
		game.new_piece()
	} else {
		game.draw_plr(true)

		let input = read_key()
		if input == "Esc" => break

		game.update(input)
	}

	game.draw_plr()
	game.print_board(true)
	println("Score:", game.score)
}
