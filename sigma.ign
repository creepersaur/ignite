import Tetris from "tetris"
import Piece from "pieces"

using Std::IO::read_key

let game = new Tetris()
let player_piece = new Piece("t_piece", 3, 2)

player_piece.draw(game)
game.print_board(true)

loop {
	player_piece.draw(game, true)

	let input = read_key()
	match input {
		"a" => player_piece.x -= 1,
		"d" => player_piece.x += 1,

		_ => player_piece.y += 1
	}

	player_piece.draw(game)

	game.print_board(true)
}
